# ARLI Production Environment Variables
# Copy to .env and fill in real values

# ============================================
# DATABASE (PostgreSQL)
# ============================================
DATABASE_URL=postgresql://arli:secure_password@localhost:5432/arli_prod
DB_USER=arli
DB_PASSWORD=secure_password_here
DB_NAME=arli_prod

# ============================================
# REDIS (Task Queue)
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# ICP (Internet Computer)
# ============================================
# Network: 'ic' for mainnet, 'local' for development
ICP_NETWORK=ic

# Your ICP identity private key (PEM format)
# Get from: dfx identity export default
ICP_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----
...
-----END EC PRIVATE KEY-----"

# Principal of your platform wallet (receives fees)
PLATFORM_PRINCIPAL=rdmx6-jaaaa-aaaaa-aaadq-cai

# Canister IDs (after deploying to ICP)
EXPERIENCE_REGISTRY_CANISTER_ID=
AGENT_NFT_CANISTER_ID=
SKILLS_MARKETPLACE_CANISTER_ID=

# ============================================
# EXTERNAL APIs (Real)
# ============================================
# OpenAI (GPT-4 for content generation)
OPENAI_API_KEY=sk-...

# Binance (for trading tasks)
BINANCE_API_KEY=
BINANCE_SECRET=

# Optional: Other exchange APIs
COINBASE_API_KEY=
COINBASE_SECRET=

# ============================================
# FRONTEND
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_ICP_NETWORK=ic

# ============================================
# MONITORING
# ============================================
# Sentry for error tracking
SENTRY_DSN=

# Prometheus metrics
METRICS_PORT=9090

# ============================================
# SECURITY
# ============================================
# JWT Secret for API authentication
JWT_SECRET=change_this_to_random_string

# Rate limiting
RATE_LIMIT_PER_MINUTE=100
